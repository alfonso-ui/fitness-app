# Copy this file to apps/mobile/.env and fill in your own values.
#   cp .env.example apps/mobile/.env
#
# The EXPO_PUBLIC_ prefix means the value is bundled into the app and is
# readable by anyone who installs it. That is fine for the two values
# below — the anon key is designed for client use and Row Level Security
# is what actually protects user data.
#
# NEVER put the Supabase service_role / secret key here, or anywhere in
# this repo. It bypasses every security rule.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
